{
  "manifest_version": 2,
  "name": "NaukriPlusPlus",
  "version": "1.0",

  "description": "Adds accurate numbers to applicants for each job.",

  "permissions" : [
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "content_scripts": [
    {
      "matches": ["*://www.naukri.com/*"],
      "js": ["naukriplus.js"],
      "run_at" : "document_start"
    }
  ],
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "browser_action": {
    "default_icon": "icons/icon.svg",
    "default_title": "NaukriPlusPlus"
  }
}